  publisher = {Academic Press},
  doi = {10.1016/B978-0-12-813387-3.00002-0},
  abstract = {An important class of spatial models can be traced back to the work of Cliff and Ord, 1973, Cliff and Ord, 1981, which have since been generalized. In Section 2.1 we present and discuss a linear form of a model that contains a spatial lag of the dependent variable, spatially lagged exogenous regressors, and a spatially autocorrelated error term. We also introduce the important concept of triangular arrays which is a distinctive characteristic of spatial models. In later sections we discuss issues relating to the parameter space, normalizations, and an important condition used in spatial models. Sections 2.2, 2.3, and 2.4 are the core of this chapter since they deal with the estimation of cross-sectional spatial models, as well as the development of a generalized moments estimator, and the corresponding instrumental variable estimator. Finally, in Section 2.4 the maximum likelihood approach is reviewed. Sections 2.5 and 2.6 conclude the chapter.},
  isbn = {978-0-12-813387-3},
  keywords = {Consistent estimation,Gersgorin's theorem,GMM estimation,Heteroskedasticity,Illustration,Maximum likelihood,Proper normalization,Spatial correlation,Spatial lag,Triangular array}
}

