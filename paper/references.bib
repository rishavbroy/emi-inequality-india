@online{basu2006,
  title = {Teacher {{Truancy}} in {{India}}: {{The Role}} of {{Culture}}, {{Norms}} and {{Economic Incentives}}},
  shorttitle = {Teacher {{Truancy}} in {{India}}},
  author = {Basu, Kaushik},
  date = {2006-01},
