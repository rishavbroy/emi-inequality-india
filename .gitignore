# temporary application sample assembly files
application-samples/.work/

# temporary files to help auditing and debugging
Archive.zip
full_output.txt

# keep deliberate TeX source templates if any remain
!application-samples/templates/*.tex
!application-samples/cover-notes/**/*.tex
!archive/application-sample-sources/*.tex
!archive/application-sample-sources/original-cover-note-tex/**/*.tex

# operating-system metadata
.DS_Store
__MACOSX/
__pycache__/

# survey-download executables and autorun files
*.exe
autorun.inf
/.quarto/
**/*.quarto_ipynb
