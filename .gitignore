# R session files
.RData
.RDataTmp
.Rhistory
.Rproj.user/
*.Rproj

# renv local files
renv/library/
renv/staging/
renv/python/
renv/sandbox/

# targets cache
_targets/
_targets.Rout

# raw, future, and intermediate data
data/raw/
data/raw_future/
data/interim/

# locally stored literature PDFs
relevant-literature/

# generated caches and render byproducts
*_cache/
*_files/
*.nb.html
*.log
*.aux
*.out
*.toc
*.synctex.gz
*.fls
*.fdb_latexmk
*.bbl
